rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    // Checks users/{uid}.role == 'admin' in Firestore — matches the app-level
    // auth check (useAuth().user.role). No custom claims needed.
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Existing collections ─────────────────────────────────────────────────
    // TODO: tighten these rules for each collection as needed.

    match /athletes/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /competitions/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{doc} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /assignments/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /wcaRecords/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /athleteRequests/{doc} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /matchHistory/{doc} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /pointTransactions/{doc} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // ─── Virtual Competitions ─────────────────────────────────────────────────

    match /virtualCompetitions/{compId} {
      allow read: if resource.data.status != 'draft' || isAdmin();
      allow write: if isAdmin();

      match /rounds/{roundId} {
        allow read: if get(/databases/$(database)/documents/virtualCompetitions/$(compId)).data.status != 'draft' || isAdmin();
        allow write: if isAdmin();
      }

      match /participants/{uid} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == uid;
        allow update: if isSignedIn() && request.auth.uid == uid;
        allow delete: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      }

      match /participantResults/{resultId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.auth.uid == resultId.split('_')[0];
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }

      match /attempts/{attemptId} {
        allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow read: if isAdmin();
        allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
        allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
        allow delete: if isAdmin();

        match /results/{resultId} {
          allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
          allow read: if isAdmin();
          allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
          allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
          allow update: if isAdmin();
          allow delete: if isAdmin();
        }
      }
    }

    // Collection group rule — enables collectionGroup('attempts') queries filtered by uid
    match /{path=**}/attempts/{attemptId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow read: if isAdmin();
    }

  }
}
